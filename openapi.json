    "/workspaces/{workspace_id}/posts": {
      "parameters": [
        { "$ref": "#/components/parameters/workspaceId" }
      ],
      "get": {
        "tags": ["posts"],
        "summary": "List posts",
        "parameters": [
          { "$ref": "#/components/parameters/page" },
          { "$ref": "#/components/parameters/perPage" },
          { "name": "status",         "in": "query", "schema": { "$ref": "#/components/schemas/PostStatus" } },
          { "name": "platform",       "in": "query", "schema": { "$ref": "#/components/schemas/Platform" } },
          { "name": "account_id",     "in": "query", "schema": { "$ref": "#/components/schemas/UUID" } },
          { "name": "tag",            "in": "query", "schema": { "type": "string" } },
          { "name": "scheduled_from", "in": "query", "schema": { "$ref": "#/components/schemas/ISO8601" } },
          { "name": "scheduled_to",   "in": "query", "schema": { "$ref": "#/components/schemas/ISO8601" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of posts.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["data", "meta"],
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Post" } },
                    "meta": { "$ref": "#/components/schemas/PaginationMeta" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["posts"],
        "summary": "Create a post (draft or scheduled)",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PostWrite" } } }
        },
        "responses": {
          "201": { "description": "Post created.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Post" } } } },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      }
    },
    "/workspaces/{workspace_id}/posts/{post_id}": {
      "parameters": [
        { "$ref": "#/components/parameters/workspaceId" },
        { "$ref": "#/components/parameters/postId" }
      ],
      "get": {
        "tags": ["posts"],
        "summary": "Get a post",
        "responses": {
          "200": { "description": "Post.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Post" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["posts"],
        "summary": "Replace a post (full update)",
        "description": "Replaces the entire post. Only allowed when status is `draft` or `scheduled`.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PostWrite" } } }
        },
        "responses": {
          "200": { "description": "Updated post.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Post" } } } },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      },
      "patch": {
        "tags": ["posts"],
        "summary": "Partially update a post",
        "description": "Partial update. Use status `cancelled` to cancel a scheduled post.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PostPatch" } } }
        },
        "responses": {
          "200": { "description": "Updated post.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Post" } } } },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      },
      "delete": {
        "tags": ["posts"],
        "summary": "Delete a post",
        "description": "Only drafts and cancelled posts may be deleted.",
        "responses": {
          "204": { "$ref": "#/components/responses/NoContent" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/workspaces/{workspace_id}/posts/{post_id}/publishes": {
      "parameters": [
        { "$ref": "#/components/parameters/workspaceId" },
        { "$ref": "#/components/parameters/postId" }
      ],
      "get": {
        "tags": ["publishes"],
        "summary": "List publish attempts for a post",
        "responses": {
          "200": {
            "description": "Array of publish records.",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Publish" } } } }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/workspaces/{workspace_id}/posts/{post_id}/publishes/{publish_id}": {
      "parameters": [
        { "$ref": "#/components/parameters/workspaceId" },
        { "$ref": "#/components/parameters/postId" },
        { "$ref": "#/components/parameters/publishId" }
      ],
      "get": {
        "tags": ["publishes"],
        "summary": "Get a publish attempt",
        "responses": {
          "200": { "description": "Publish record.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Publish" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/workspaces/{workspace_id}/posts/{post_id}/retry": {
      "parameters": [
        { "$ref": "#/components/parameters/workspaceId" },
        { "$ref": "#/components/parameters/postId" }
      ],
      "post": {
        "tags": ["publishes"],
        "summary": "Retry a failed post",
        "description": "Creates a new publish attempt for all failed targets. Only allowed when post status is `failed`.",
        "responses": {
          "202": {
            "description": "Retry accepted, new publish records created.",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Publish" } } } }
          },
          "409": { "$ref": "#/components/responses/Conflict" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/workspaces/{workspace_id}/calendar": {
      "parameters": [
        { "$ref": "#/components/parameters/workspaceId" }
      ],
      "get": {
        "tags": ["calendar"],
        "summary": "Get calendar entries for a date range",
        "description": "Returns lightweight post summaries ordered by scheduled_at. Ideal for rendering a calendar view.",
        "parameters": [
          { "name": "from",       "in": "query", "required": true, "schema": { "type": "string", "format": "date", "examples": ["2026-05-01"] } },
          { "name": "to",         "in": "query", "required": true, "schema": { "type": "string", "format": "date", "examples": ["2026-05-31"] } },
          { "name": "platform",   "in": "query", "schema": { "$ref": "#/components/schemas/Platform" } },
          { "name": "account_id", "in": "query", "schema": { "$ref": "#/components/schemas/UUID" } },
          { "name": "status",     "in": "query", "schema": { "$ref": "#/components/schemas/PostStatus" } }
        ],
        "responses": {
          "200": {
            "description": "Calendar entries.",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CalendarEntry" } } } }
          },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      }
    },
    "/workspaces/{workspace_id}/schedules": {
      "parameters": [
        { "$ref": "#/components/parameters/workspaceId" }
      ],
      "get": {
        "tags": ["schedules"],
        "summary": "List recurring schedule templates",
        "responses": {
          "200": {
            "description": "Array of schedules.",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Schedule" } } } }
          }
        }
      },
      "post": {
        "tags": ["schedules"],
        "summary": "Create a recurring schedule template",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "cron", "timezone", "account_ids"],
                "properties": {
                  "name":        { "type": "string" },
                  "cron":        { "type": "string", "examples": ["0 9 * * 1,3,5"] },
                  "timezone":    { "type": "string", "examples": ["Europe/Tallinn"] },
                  "account_ids": { "type": "array", "items": { "$ref": "#/components/schemas/UUID" }, "minItems": 1 },
                  "enabled":     { "type": "boolean", "default": true }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Schedule created.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Schedule" } } } },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      }
    },
    "/workspaces/{workspace_id}/schedules/{schedule_id}": {
      "parameters": [
        { "$ref": "#/components/parameters/workspaceId" },
        { "$ref": "#/components/parameters/scheduleId" }
      ],
      "get": {
        "tags": ["schedules"],
        "summary": "Get a schedule template",
        "responses": {
          "200": { "description": "Schedule.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Schedule" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["schedules"],
        "summary": "Replace a schedule template",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "cron", "timezone", "account_ids", "enabled"],
                "properties": {
                  "name":        { "type": "string" },
                  "cron":        { "type": "string" },
                  "timezone":    { "type": "string" },
                  "account_ids": { "type": "array", "items": { "$ref": "#/components/schemas/UUID" }, "minItems": 1 },
                  "enabled":     { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated schedule.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Schedule" } } } },
          "404": { "$ref": "#/components/responses/NotFound" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      },
      "patch": {
        "tags": ["schedules"],
        "summary": "Partially update a schedule template",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name":        { "type": "string" },
                  "cron":        { "type": "string" },
                  "timezone":    { "type": "string" },
                  "account_ids": { "type": "array", "items": { "$ref": "#/components/schemas/UUID" }, "minItems": 1 },
                  "enabled":     { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated schedule.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Schedule" } } } },
          "404": { "$ref": "#/components/responses/NotFound" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      },
      "delete": {
        "tags": ["schedules"],
        "summary": "Delete a schedule template",
        "description": "Deletes the template. Previously generated posts are not affected.",
        "responses": {
          "204": { "$ref": "#/components/responses/NoContent" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/workspaces/{workspace_id}/schedules/{schedule_id}/posts": {
      "parameters": [
        { "$ref": "#/components/parameters/workspaceId" },
        { "$ref": "#/components/parameters/scheduleId" }
      ],
      "get": {
        "tags": ["schedules"],
        "summary": "List posts generated by a schedule template",
        "parameters": [
          { "$ref": "#/components/parameters/page" },
          { "$ref": "#/components/parameters/perPage" }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of posts.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["data", "meta"],
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Post" } },
                    "meta": { "$ref": "#/components/schemas/PaginationMeta" }
                  }
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  }
}
